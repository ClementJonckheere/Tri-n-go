{% extends "layout.twig" %}
{% block content %}
    <div class="admin-form-page">
        <div class="admin-form-card">
            <div class="admin-form-header">
                <h1>Créer un agent ou chef d’agent</h1>
                <p>Ajoute un nouvel utilisateur aux équipes terrain et définis son périmètre.</p>
            </div>

            {% if error %}
                <p class="admin-form-alert">{{ error }}</p>
            {% endif %}

            <form method="post" action="/admin/agents" class="admin-form">
                <div class="admin-form-field">
                    <label for="name">Nom</label>
                    <input type="text" id="name" name="name" required>
                </div>

                <div class="admin-form-field">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" required>
                </div>

                <div class="admin-form-field">
                    <label for="password">Mot de passe</label>
                    <input type="password" id="password" name="password" required>
                </div>

                <div class="admin-form-field">
                    <label for="role">Type d’utilisateur</label>
                    <select id="role" name="role">
                        <option value="agent">Agent</option>
                        <option value="chef_agent">Chef d’agent</option>
                    </select>
                </div>

                <div class="admin-form-field admin-form-field-full">
                    <label for="perimetreVille">Ville / périmètre géré</label>
                    <input type="text" id="perimetreVille" name="perimetreVille" placeholder="Ex : Amiens">
                </div>

                <div class="admin-form-field admin-form-field-full">
                    <label for="chefAgentId">Chef d’agent (si agent simple)</label>
                    <select id="chefAgentId" name="chefAgentId">
                        <option value="">Aucun / Chef non défini</option>
                        {% if chefs %}
                            {% for c in chefs %}
                                <option value="{{ c._id }}">
                                    {{ c.name }}{% if c.perimetreVille %} ({{ c.perimetreVille }}){% endif %}
                                </option>
                            {% endfor %}
                        {% endif %}
                    </select>
                </div>

                <div class="admin-form-actions admin-form-field-full">
                    <button type="submit" class="btn-primary">Créer</button>
                    <a href="/admin/utilisateurs" class="btn-secondary">Annuler</a>
                </div>
            </form>
        </div>
    </div>
{% endblock %}
