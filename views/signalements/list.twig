{% extends "layout.twig" %}

{% block title %}Mes signalements{% endblock %}

{% block content %}
    <section class="signalements-page">
        <div class="signalements-header">
            <h1>Mes signalements</h1>
            <p class="signalements-subtitle">
                Retrouve ici l’historique de tes déclarations d’encombrants.
            </p>
        </div>

        {% if signalements.length == 0 %}
            <p class="signalements-empty">
                Aucun signalement pour le moment.
            </p>
        {% else %}
            <div class="signalements-table-wrapper">
                <table class="signalements-table">
                    <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Description</th>
                        <th>Ville</th>
                        <th>Code postal</th>
                        <th>Adresse</th>
                        <th>Photo</th>
                        <th>Statut</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for s in signalements %}
                        <tr>
                            <td>{{ s.dateSignalement|date('d/m/Y H:i') }}</td>
                            <td>{{ s.typeEncombrant }}</td>
                            <td>{{ s.description }}</td>
                            <td>{{ s.ville }}</td>
                            <td>{{ s.codePostal }}</td>
                            <td>{{ s.adresse }}</td>
                            <td>
                                {% if s.photoFilename %}
                                    <img
                                            src="/uploads/{{ s.photoFilename }}"
                                            alt="Photo de l’encombrant"
                                            class="signalement-photo"
                                    >
                                {% else %}
                                    <span class="photo-empty">–</span>
                                {% endif %}
                            </td>
                            <td>
                <span class="statut-pill statut-{{ s.statut }}">
                  {{ s.statut|capitalize }}
                </span>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </section>
{% endblock %}
