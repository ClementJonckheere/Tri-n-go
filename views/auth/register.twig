{% extends "layout.twig" %}

{% block title %}Créer un compte citoyen - Tri’n Go{% endblock %}

{% block content %}
    <style>

    </style>

    <div class="auth-wrapper">
        <div class="auth-card">

            <div class="auth-illustration" aria-hidden="true"></div>

            <div class="auth-panel">
                <div class="auth-header">
                    <div>
                        <p class="auth-eyebrow">Rejoignez Tri’n Go</p>
                        <h1 class="auth-title">Créez votre compte</h1>
                        <p class="auth-subtitle">
                            Inscrivez-vous pour déclarer vos encombrants.
                        </p>
                    </div>
                </div>

                {% if error %}
                    <p style="color:#c0392b; font-size:14px; margin-bottom:10px;">
                        {{ error }}
                    </p>
                {% endif %}

                <form method="post" action="/register" class="auth-form">
                    <div class="field-group">
                        <label for="name" class="field-label">Nom complet</label>
                        <div class="field-control">
                            <span class="field-prefix">👤</span>
                            <input type="text" id="name" name="name"
                                   class="field-input"
                                   placeholder="Votre nom"
                                   required>
                        </div>
                    </div>

                    <div class="field-group">
                        <label for="email" class="field-label">Email</label>
                        <div class="field-control">
                            <span class="field-prefix">✉️</span>
                            <input type="email" id="email" name="email"
                                   class="field-input"
                                   placeholder="votre@email.fr"
                                   required>
                        </div>
                    </div>

                    <div class="field-group">
                        <label for="password" class="field-label">Mot de passe</label>
                        <div class="field-control">
                            <span class="field-prefix">🔒</span>
                            <input type="password" id="password" name="password"
                                   class="field-input"
                                   placeholder="Choisissez un mot de passe"
                                   required>
                        </div>
                    </div>

                    {# Ville + Code postal sur la même ligne, avec le même style #}
                    <div class="field-row-2cols">
                        <div class="field-group">
                            <label for="ville" class="field-label">Ville</label>
                            <div class="field-control">
                                <span class="field-prefix">📍</span>
                                <input type="text"
                                       id="ville"
                                       name="ville"
                                       class="field-input"
                                       placeholder="Amiens"
                                       required>
                            </div>
                        </div>

                        <div class="field-group">
                            <label for="codePostal" class="field-label">Code postal</label>
                            <div class="field-control">
                                <span class="field-prefix">🏷️</span>
                                <input type="text"
                                       id="codePostal"
                                       name="codePostal"
                                       class="field-input"
                                       placeholder="80000"
                                       required>
                            </div>
                        </div>
                    </div>

                    <div class="field-group">
                        <label for="adresse" class="field-label">Adresse</label>
                        <div class="field-control">
                            <span class="field-prefix">🏠</span>
                            <input type="text" id="adresse" name="adresse"
                                   class="field-input"
                                   placeholder="15 rue du pont"
                                   required>
                        </div>
                    </div>

                    <div class="auth-actions">
                        <button type="submit" class="btn btn-primary" id="login">
                            Créer mon compte
                        </button>
                    </div>
                </form>

                <p class="auth-footer">
                    Vous avez déjà un compte ? <a href="/login">Se connecter</a>
                </p>
            </div>
        </div>
    </div>
{% endblock %}
